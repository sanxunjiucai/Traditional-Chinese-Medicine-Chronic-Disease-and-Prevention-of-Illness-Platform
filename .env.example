# 数据库（Docker Compose 默认）
DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/tcm
# 测试数据库（pytest 使用独立库）
TEST_DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/tcm_test

# JWT 认证
SECRET_KEY=changeme-please-use-a-long-random-string-in-production
ALGORITHM=HS256
# 7天过期（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# DEMO_MODE=true 时启动时自动执行 seed（开发/演示用）
DEMO_MODE=false
